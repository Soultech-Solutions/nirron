# API (Directus)
# Apenas a URL pública do Directus é exposta ao navegador.
# Nunca coloque senha, refresh token ou token estático privilegiado em variáveis VITE_*.
#
# Desenvolvimento (.env / .env.local): use o proxy do Vite (evita CORS):
#   VITE_API_BASE_URL=/directus
# Produção (.env.production): use a URL absoluta — o Vite embute isso no build:
#   VITE_API_BASE_URL=https://mailminer.soultech.solutions
# Garanta que o domínio do frontend esteja em CORS_ORIGIN no Directus.
VITE_API_BASE_URL=/directus
VITE_API_TIMEOUT=30000

# Autenticação mockada (desenvolvimento offline). Use 'true' para logar sem backend.
# false = Directus real (mailminer.soultech.solutions via proxy /directus)
VITE_USE_MOCK_AUTH=false

# CE Mercante API
# Dev: proxy Vite → /mercante/ce
# Prod (.env.production): https://nirron-mercante.soultech.solutions/ce
VITE_MERCANTE_API_URL=/mercante/ce

# Aplicação
VITE_APP_NAME=NIRRON
VITE_APP_VERSION=0.1.0
